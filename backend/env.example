# === AUTODESK PLATFORM SERVICES ===
APS_CLIENT_ID=your_client_id_here
APS_CLIENT_SECRET=your_client_secret_here
CALLBACK_URL=http://localhost:3000/callback
# La app usa el mismo Client ID/Secret para OAuth 3-legged (usuario) y token 2-legged
# (bucket:create bucket:read bucket:delete data:read data:write) para OSS + Model Derivative en objetos OSS.

# Modo "Solo ver demo" (sin login): URN base64 de un .rvt/.nwc ya subido a OSS de ESTA app y con derivados listos.
# Si se omite, el botón de demo no aparece. No uses URN de ACC/WIP aquí.
# DEMO_URN_BASE64=
# DEMO_MODEL_LABEL=Modelo de ejemplo
# DEMO_PUBLIC_ENABLED=true
# DEMO_MD_BASIC_MONTHLY_CAP=180000
# DEMO_DM_BASIC_MONTHLY_CAP=180000
# DEMO_MD_SIMPLE_JOBS_MONTHLY_CAP=4
# DEMO_MD_COMPLEX_JOBS_MONTHLY_CAP=4
# DEMO_USAGE_WARNING_THRESHOLD=0.8
# DEMO_USAGE_STORE_PATH=./data/demo-usage.json
# DEMO_EXTRACT_RATE_WINDOW_MS=600000
# DEMO_EXTRACT_RATE_MAX_PER_IP=3
# DEMO_READ_RATE_WINDOW_MS=60000
# DEMO_READ_RATE_MAX_PER_IP=20
# DEMO_CAPTCHA_ENABLED=true
# DEMO_CAPTCHA_PROVIDER=turnstile
# DEMO_CAPTCHA_SITE_KEY=
# DEMO_CAPTCHA_SECRET=
# DEMO_CAPTCHA_PASS_TTL_MS=1800000

# === SERVIDOR ===
# Convención local: backend :3000, frontend (CRA) :3001
PORT=3000
NODE_ENV=development
# URL base del frontend (redirecciones OAuth /logout y GET /)
FRONTEND_URL=http://localhost:3001
# Orígenes permitidos para CORS (separados por coma). Por defecto usa FRONTEND_URL.
# Ejemplo producción:
# FRONTEND_URLS=https://aps-data.arqfi.com
FRONTEND_URLS=http://localhost:3001

# === SECRETOS ===
SESSION_SECRET=your_random_secret_key_here
